# Serial Port Configuration
SERIAL_PORT=/dev/cu.usbmodem113401
BAUD_RATE=9600

# Discord Webhook Configuration (Direct sending)
DISCORD_WEBHOOK_URL=your_discord_webhook_url_here

# Sending Interval (in seconds, e.g., 300 = 5 minutes)
SEND_INTERVAL=300

# (Optional) Hermes Agent Configuration - for future expansion
HERMES_API_URL=http://127.0.0.1:8642/v1/chat/completions
HERMES_API_KEY=your_hermes_api_key_here
